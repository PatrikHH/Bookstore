@using Bookstore.DTO
@model BookInStoreDTO
@{
    ViewData["Title"] = "Edit book";
}
<div>
    <h4>Update book</h4>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
    <form asp-action="Edit">
        <div class="form-group">
            <label asp-for="Name">Name</label>
            <input type="text" asp-for="Name" class="form-control" />
            <label asp-for="Author">Author</label>
            <input type="text" asp-for="Author" class="form-control" />
            <label asp-for="ISBN">ISBN</label>
            <input type="text" asp-for="ISBN" class="form-control" />
            <label asp-for="Quantity">Quantity</label>
            <input type="text" asp-for="Quantity" class="form-control" />
            <label asp-for="BooksSectionId" class="control-label">Books Section</label>
            <select asp-for="BooksSectionId" asp-items="ViewBag.BooksSections" class="form-control"></select>
            <label asp-for="Price">Price</label>
            <input type="text" asp-for="Price" class="form-control" />
            <div>
                <input class="btn btn-success" type="submit" formmethod="post" value="Update" />
            </div>
    </form>
</div>